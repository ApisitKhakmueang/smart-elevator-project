# 1. ใช้ Python 3.10-slim เพื่อขนาด Image ที่เล็กและติดตั้ง Library ได้ครบ
FROM python:3.10-slim

# 2. ตั้งค่า Environment Variables สำหรับระบบ Log และ Port
ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PORT=8080

# 3. ติดตั้ง Dependencies พื้นฐานของระบบ Linux ที่ AI Library จำเป็นต้องใช้
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    libgl1-mesa-glx \
    libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

# 4. กำหนด Working Directory ภายใน Container
WORKDIR /app

# 5. ติดตั้ง Python Library จากไฟล์ requirements.txt ใหม่ของคุณ
COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt

# 6. คัดลอกไฟล์ทั้งหมด (server.py, โฟลเดอร์ model/ และไฟล์โมเดล) เข้าไป
COPY . .

# 7. แจ้ง Port ที่จะใช้สื่อสาร (Railway จะส่งค่านี้มาให้ผ่าน ENV)
EXPOSE 8080

# 8. คำสั่งเริ่มรัน Server โดยใช้ Uvicorn
# ดึงค่าพอร์ตจาก $PORT ที่ Railway กำหนดให้โดยอัตโนมัติ
CMD ["sh", "-c", "uvicorn server:app --host 0.0.0.0 --port ${PORT}"]